# Bearer token clients must present as: Authorization: Bearer <token>
# Also used as the consent-page password when MCP_CONSENT_PASSWORD is unset.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
MCP_AUTH_TOKEN=replace_me_with_long_random_token

# Optional separate password for the /authorize consent page. When set, the
# browser-facing form accepts this instead of MCP_AUTH_TOKEN, so the master
# bearer is never typed into a browser. Rotate independently. If unset,
# MCP_AUTH_TOKEN covers both roles (original behaviour).
# MCP_CONSENT_PASSWORD=replace_me_with_another_long_random_token

# Port the MCP server listens on (internal). Tailscale Funnel maps
# external 443 -> this port; configure Funnel separately.
PORT=8765

# SQLite database path. In Docker this is /data/events.db on the mounted volume.
DB_PATH=data/events.db

# Separate SQLite file for OAuth state (access tokens). Kept apart from the
# events DB so that wiping events during ingest iteration does not blow away
# tokens claude.ai has cached for the connector.
OAUTH_DB_PATH=data/oauth.db

# How long OAuth-issued access tokens stay valid. Rotating MCP_AUTH_TOKEN
# does NOT revoke already-issued tokens — to revoke, delete rows from
# oauth_tokens in OAUTH_DB_PATH.
OAUTH_TOKEN_TTL_DAYS=90

# Comma-separated allowlist of redirect_uri prefixes accepted by /authorize.
# Default covers claude.ai and localhost dev. Add your own only if you know
# why you're doing it (open-redirect risk).
# OAUTH_REDIRECT_URI_ALLOWLIST=https://claude.ai/api/mcp/auth_callback,http://localhost,http://127.0.0.1

# Which upstream IPs uvicorn trusts X-Forwarded-* headers from. Defaults to
# 127.0.0.1 (Tailscale Funnel runs on the host, so the request arrives via
# loopback). If you put a Docker reverse proxy in front, set this to the
# bridge subnet (e.g. 172.16.0.0/12) — never to a wildcard.
# FORWARDED_ALLOW_IPS=127.0.0.1
